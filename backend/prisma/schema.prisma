generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  role      String
  createdAt DateTime @default(now())
}

model Equipment {
  id        Int      @id @default(autoincrement())
  name      String
  serial    String?
  createdAt DateTime @default(now())

  workOrders WorkOrder[]
}

model WorkOrder {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String
  createdAt   DateTime @default(now())

  equipmentId Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
}
